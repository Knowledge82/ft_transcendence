generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Modelo de usuario: datos base de autenticación y perfil
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String // Nunca guardamos la contraseña en texto plano, solo el hash
  displayName  String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
