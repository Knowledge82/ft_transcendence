# .env.example - Este es un patrón de incorporación estándar en cualquier proyecto web; sin él, una persona simplemente no entenderá qué variables deben completarse para que todo funcione.

# Postgres
POSTGRES_USER=ft_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=ft_transcendence

# Backend
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
NODE_ENV=development

# Frontend (Si necesitas variables públicas de Vite)
VITE_API_URL=https://localhost/api
